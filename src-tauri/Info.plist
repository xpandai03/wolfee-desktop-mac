<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
		TCC purpose strings. Required by macOS Catalina+ in addition to the
		Hardened Runtime entitlements in ../entitlements.plist. Without
		NSMicrophoneUsageDescription, macOS silently zero-fills the cpal
		input callback buffers — no prompt, no error, just silence. The
		Phase 3 Deepgram verification on 2026-05-03 found this the hard
		way (Layer A diagnostic showed max_abs=0.0 across 65s of clear
		speech).
	-->
	<key>NSMicrophoneUsageDescription</key>
	<string>Wolfee Copilot listens to your meeting audio so it can show you live insights and follow-up suggestions during the call. Audio is captured only while a Copilot session is active.</string>
	<key>NSScreenCaptureUsageDescription</key>
	<string>Wolfee captures your computer's audio output so it can transcribe the other parties on a call. When you record a screen video, the display you choose is also captured.</string>
	<!--
		Camera permission. Not used yet — the Phase 1 screen recorder
		captures screen + audio only. Added now so the Phase 2 webcam
		bubble won't need a separate signed release just to introduce
		a usage string. macOS only prompts for camera access the first
		time an AVCaptureDevice is actually opened.
	-->
	<key>NSCameraUsageDescription</key>
	<string>Wolfee uses your camera to record a webcam bubble alongside your screen recordings.</string>
</dict>
</plist>
