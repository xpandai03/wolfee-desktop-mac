{
  "$schema": "https://raw.githubusercontent.com/nicosantangelo/tauri-schema/refs/heads/main/src/tauri.conf.schema.json",
  "productName": "Wolfee Desktop",
  "identifier": "io.wolfee.desktop",
  "version": "0.4.9",
  "build": {
    "frontendDist": "../overlay/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm --dir overlay dev",
    "beforeBuildCommand": "pnpm --dir overlay build"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "Developer ID Application: XPAND TECHNOLOGY LLC (LT73Z72CKR)",
      "entitlements": "../entitlements.plist",
      "exceptionDomain": null,
      "minimumSystemVersion": "13.0",
      "infoPlist": "Info.plist"
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com"
    },
    "externalBin": ["binaries/ffmpeg"]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
