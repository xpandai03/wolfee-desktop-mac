{
  "name": "wolfee-desktop",
  "version": "0.1.2",
  "description": "Wolfee Desktop Recorder — invisible meeting recorder",
  "main": "dist/main/index.js",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && electron .",
    "dev": "tsc && electron .",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:unsigned": "CSC_IDENTITY_AUTO_DISCOVERY=false npm run build && electron-builder",
    "verify": "bash scripts/verify.sh",
    "dev:install": "bash scripts/dev-install.sh",
    "dev:run": "rm -rf dist release && npm run build && npx electron-builder --mac --arm64 && npm run dev:install",
    "release": "node scripts/release.js"
  },
  "author": "Wolfee",
  "license": "PRIVATE",
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1010.0",
    "@electron/notarize": "^3.1.1",
    "@types/fluent-ffmpeg": "^2.1.21",
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.7",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "axios": "^1.6.5",
    "electron-store": "^8.1.0",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.2",
    "form-data": "^4.0.0",
    "uuid": "^9.0.0"
  }
}
